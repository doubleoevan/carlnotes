# CarlNotes environment variables
# Doppler (project: carlnotes) is the source of truth; a gitignored .env works as the fallback.
# Copy to .env, fill in the required section, never commit a real .env.

# ---- required: the model proxy (all you need today) ----

# fireworks: llm inference behind litellm
FIREWORKS_API_KEY=fw_xxxxxxxx

# litellm: master key for the local proxy admin and virtual key management (any long random string)
LITELLM_MASTER_KEY=sk-change-me

# postgres (neon): separate database for the litellm proxy (virtual keys, spend tracking)
LITELLM_DATABASE_URL=postgresql://user:password@host/litellm?sslmode=require

# ---- app runtime: only needed once the app ships ----

# postgres (neon): the app database, pgvector enabled
DATABASE_URL=postgresql://user:password@host/carlnotes?sslmode=require

# exa: semantic web search for source discovery
EXA_API_KEY=xxxxxxxx

# firecrawl: url content fetching
FIRECRAWL_API_KEY=fc-xxxxxxxx

# youtube data api v3: youtube source adapter
YOUTUBE_API_KEY=xxxxxxxx

# resend: transactional and digest email
RESEND_API_KEY=re_xxxxxxxx

# better auth: session secret (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=xxxxxxxx

# Object storage: Cloudflare R2 via S3 API (self-hosted: point at MinIO or S3)
S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=carlnotes-dev
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Bot protection: Cloudflare Turnstile (always-pass test keys, valid on localhost)
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA