{
	"name": "carlnotes",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev:ui": "doppler run --command \"cd ui && vite\"",
		"dev:api": "doppler run -- bun --watch api/index.ts",
		"build:ui": "cd ui && vite build",
		"check": "bash scripts/preflight.sh",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "doppler run -- drizzle-kit migrate",
		"db:seed": "doppler run -- bun api/seed.ts",
		"test": "bun test",
		"smoke": "bun run smoke:scan && bun run smoke:attach && bun run smoke:search",
		"smoke:scan": "doppler run -- bun worker/scan.smoke.ts",
		"smoke:attach": "doppler run -- bun worker/attach.smoke.ts",
		"smoke:search": "doppler run -- bun worker/search.smoke.ts",
		"prompts:sync": "doppler run -- bun worker/prompts/sync.ts"
	},
	"dependencies": {
		"@ai-sdk/openai": "^4.0.14",
		"@hono/zod-validator": "^0.9.0",
		"@langfuse/client": "^5.9.1",
		"@langfuse/otel": "^5.9.1",
		"@langfuse/tracing": "^5.9.1",
		"@langfuse/vercel-ai-sdk": "^5.9.1",
		"@neondatabase/serverless": "^1.1.0",
		"@opentelemetry/sdk-node": "^0.221.0",
		"@radix-ui/react-accordion": "^1.2.16",
		"@radix-ui/react-alert-dialog": "^1.1.21",
		"@radix-ui/react-label": "^2.1.11",
		"@radix-ui/react-popover": "^1.1.19",
		"@radix-ui/react-select": "^2.3.3",
		"@radix-ui/react-slot": "^1.3.0",
		"@radix-ui/react-tooltip": "^1.2.12",
		"ai": "^7.0.28",
		"better-auth": "^1.6.24",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.45.2",
		"hono": "^4.12.30",
		"lucide-react": "^1.24.0",
		"radix-ui": "^1.6.2",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-router-dom": "^7.18.1",
		"rss-parser": "^3.13.0",
		"tailwind-merge": "^3.6.0",
		"tw-animate-css": "^1.4.0",
		"unpdf": "^1.6.2",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.3",
		"@tailwindcss/vite": "^4.3.2",
		"@types/bun": "^1.3.14",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.3",
		"drizzle-kit": "^0.31.10",
		"tailwindcss": "^4.3.2",
		"typescript": "^5.9.3",
		"vite": "^8.1.4"
	}
}
