{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "bash scripts/check-comment-groups.sh" },
          { "type": "command", "command": "bash scripts/check-structure.sh" }
        ]
      }
    ]
  },
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(cd:*)",
      "Bash(ls:*)",
      "Bash(echo:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(tr:*)",
      "Bash(cut:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(test:*)",
      "Bash(jq:*)",
      "Bash(ps:*)",
      "Bash(pgrep:*)",
      "Bash(docker ps:*)",
      "Bash(rm -f smoke.ts:*)",
      "Bash(tee /private/tmp/claude-*)",
      "Bash(python3 -c:*)",
      "Bash(python3 -m json.tool:*)",
      "Bash(git show:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git mv:*)",
      "Bash(git check-ignore:*)",
      "Bash(bun run:*)",
      "Bash(bun test:*)",
      "Bash(bun add:*)",
      "Bash(bun install:*)",
      "Bash(bunx tsc:*)",
      "Bash(bunx biome:*)",
      "Bash(bash scripts/preflight.sh:*)",
      "Bash(bash scripts/check-comment-groups.sh:*)",
      "Bash(bash scripts/check-structure.sh:*)",
      "Bash(openspec:*)",
      "Bash(coderabbit:*)",
      "Bash(gemini:*)",
      "Bash(timeout 30 gemini:*)",
      "Bash(doppler secrets --only-names:*)",
      "Bash(doppler run -- bun run:*)",
      "Bash(doppler run -- bun test:*)",
      "Bash(doppler run -- bun -e:*)",
      "Bash(doppler run -- bunx drizzle-kit:*)",
      "Bash(doppler run -- docker compose restart litellm:*)",
      "Bash(doppler run -- bash -c 'coderabbit:*)",
      "Bash(doppler run -- bash -c 'test:*)",
      "Skill(opsx:*)"
    ],
    "ask": [
      "Bash(git commit:*)",
      "Bash(git push:*)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf ./*)",
      "Bash(rm -rf ../*)",
      "Bash(rm -rf .)",
      "Bash(rm -rf ~)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(git checkout -- *)",
      "Bash(sed -i:*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.netrc)",
      "Edit(~/.ssh/**)",
      "Edit(~/.aws/**)",
      "Edit(~/.zshrc)",
      "Edit(~/.bashrc)",
      "Edit(~/.gitconfig)"
    ]
  }
}
